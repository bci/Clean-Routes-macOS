#!/usr/bin/env zsh
# .git/hooks/pre-push — installed via: make install-hooks
#
# Runs lint + tests before every push. Push is blocked if either fails.
# To skip in an emergency: git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

echo "==> pre-push: running lint + tests (use --no-verify to skip)"
echo ""

make all

echo ""
echo "==> pre-push: all checks passed."
